import sys

# 袗谢褎邪胁褨褌 蟹 32 谢褨褌械褉
ALPHABET = '邪斜胁谐写械卸蟹懈泄泻谢屑薪芯锌褉褋褌褍褎褏褑褔褕褖褗褘褜褝褞褟'
M = len(ALPHABET)


def filter_text(text):
    """袧懈卸薪褨泄 褉械谐褨褋褌褉, 蟹邪屑褨薪邪 褢 -> 械, 胁懈写邪谢械薪薪褟 薪械邪谢褎邪胁褨褌薪懈褏 褋懈屑胁芯谢褨胁."""
    text = text.lower().replace('褢', '械')
    return ''.join(c for c in text if c in ALPHABET)


def vigenere(text, key, mode='encrypt'):
    text = filter_text(text)
    key = filter_text(key)
    if not text or not key:
        return "袩芯屑懈谢泻邪: 孝械泻褋褌 邪斜芯 泻谢褞褔 锌芯褉芯卸薪褨!"

    result = []
    k_len = len(key)

    for i in range(len(text)):
        x_idx = ALPHABET.index(text[i])
        k_idx = ALPHABET.index(key[i % k_len])

        if mode == 'encrypt':
            new_idx = (x_idx + k_idx) % M
        else:
            new_idx = (x_idx - k_idx) % M

        result.append(ALPHABET[new_idx])

    return ''.join(result)


def main():
    print("--- 楔懈褎褉 袙褨卸械薪械褉邪 (袪芯褋褨泄褋褜泻懈泄 邪谢褎邪胁褨褌, 32 谢褨褌械褉懈) ---")

    while True:
        print("\n袙懈斜械褉褨褌褜 写褨褞:")
        print("1. 袟邪褕懈褎褉褍胁邪褌懈")
        print("2. 袪芯蟹褕懈褎褉褍胁邪褌懈")
        print("3. 袙懈褏褨写")

        choice = input("\n袙邪褕 胁懈斜褨褉 (1/2/3): ")

        if choice == '3':
            print("袘褍胁邪泄!")
            break

        if choice in ['1', '2']:
            mode = 'encrypt' if choice == '1' else 'decrypt'

            print(f"\n袙胁械写褨褌褜 褌械泻褋褌 写谢褟 {'褕懈褎褉褍胁邪薪薪褟' if mode == 'encrypt' else '褉芯蟹褕懈褎褉褍胁邪薪薪褟'}:")
            text_input = input("> ")

            print("袙胁械写褨褌褜 泻谢褞褔:")
            key_input = input("> ")

            result = vigenere(text_input, key_input, mode)

            print("\n" + "=" * 20)
            print(f"袪袝袟校袥鞋孝袗孝:\n{result}")
            print("=" * 20)
        else:
            print("袧械胁褨褉薪懈泄 胁懈斜褨褉, 褋锌褉芯斜褍泄褌械 褖械 褉邪蟹.")


if __name__ == "__main__":
    main()
