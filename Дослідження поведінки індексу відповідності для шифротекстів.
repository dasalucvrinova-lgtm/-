import random
from collections import Counter
import matplotlib.pyplot as plt

alphabet = "–∞–±–≤–≥–і–µ–ґ–Ј–Є–є–Ї–ї–Љ–љ–Њ–њ—А—Б—В—Г—Д—Е—Ж—З—И—Й—К—Л—М—Н—О—П"
m = len(alphabet)


# —Д—Ц–ї—М—В—А —В–µ–Ї—Б—В—Г
def filter_text(text):
    text = text.lower()
    text = text.replace("—С", "–µ")

    result = ""
    for ch in text:
        if ch in alphabet:
            result += ch

    return result


# —И–Є—Д—А—Г–≤–∞–љ–љ—П –Т—Ц–ґ–µ–љ–µ—А–∞
def vigenere_encrypt(text, key):
    result = ""

    for i in range(len(text)):
        t = alphabet.index(text[i])
        k = alphabet.index(key[i % len(key)])

        c = (t + k) % m
        result += alphabet[c]

    return result


# —Ц–љ–і–µ–Ї—Б –≤—Ц–і–њ–Њ–≤—Ц–і–љ–Њ—Б—В—Ц
def index_of_coincidence(text):

    N = len(text)
    freq = Counter(text)

    s = 0
    for f in freq.values():
        s += f * (f - 1)

    return s / (N * (N - 1))


# –≥–µ–љ–µ—А–∞—Ж—Ц—П –≤–Є–њ–∞–і–Ї–Њ–≤–Њ–≥–Њ –Ї–ї—О—З–∞
def generate_key(length):
    key = ""
    for i in range(length):
        key += random.choice(alphabet)
    return key


# -------------------------
# –Њ—Б–љ–Њ–≤–љ–∞ —З–∞—Б—В–Є–љ–∞
# -------------------------

text = input("–Т—Б—В–∞–≤—В–µ —В–µ–Ї—Б—В (3-5 –Ї–±): ")
text = filter_text(text)

# –і–Њ–≤–ґ–Є–љ–Є –Ї–ї—О—З—Ц–≤
key_lengths = [2, 3, 4, 5, 6, 10, 15, 20]

results = []

# —Ц–љ–і–µ–Ї—Б –і–ї—П –≤—Ц–і–Ї—А–Є—В–Њ–≥–Њ —В–µ–Ї—Б—В—Г
plain_ic = index_of_coincidence(text)
print("\n–Ж–љ–і–µ–Ї—Б –≤—Ц–і–њ–Њ–≤—Ц–і–љ–Њ—Б—В—Ц –≤—Ц–і–Ї—А–Є—В–Њ–≥–Њ —В–µ–Ї—Б—В—Г:", plain_ic)

results.append(plain_ic)

ic_values = []

print("\n–Ґ–∞–±–ї–Є—Ж—П —А–µ–Ј—Г–ї—М—В–∞—В—Ц–≤")
print("–Ф–Њ–≤–ґ–Є–љ–∞ –Ї–ї—О—З–∞ | –Ж–љ–і–µ–Ї—Б –≤—Ц–і–њ–Њ–≤—Ц–і–љ–Њ—Б—В—Ц")

for r in key_lengths:

    key = generate_key(r)

    cipher = vigenere_encrypt(text, key)

    ic = index_of_coincidence(cipher)

    ic_values.append(ic)

    print(f"{r}              | {ic}")


# –њ–Њ–±—Г–і–Њ–≤–∞ –≥—А–∞—Д—Ц–Ї–∞
plt.plot(key_lengths, ic_values, marker='o')

plt.xlabel("–Ф–Њ–≤–ґ–Є–љ–∞ –Ї–ї—О—З–∞")
plt.ylabel("–Ж–љ–і–µ–Ї—Б –≤—Ц–і–њ–Њ–≤—Ц–і–љ–Њ—Б—В—Ц")
plt.title("–Ч–∞–ї–µ–ґ–љ—Ц—Б—В—М IC –≤—Ц–і –і–Њ–≤–ґ–Є–љ–Є –Ї–ї—О—З–∞")

plt.show()
